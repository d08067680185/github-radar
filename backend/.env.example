# PostgreSQL
DATABASE_URL=postgresql+psycopg://radar:radar@localhost:5432/github_radar

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub tokens (逗号分隔可放多个做轮换；至少一个，否则限流极低)
GITHUB_TOKENS=ghp_xxxxxxxxxxxxxxxxxxxx

# 发现阈值：只采集 star 数 >= 该值的项目
DISCOVER_MIN_STARS=500

# 头部按 star 最多拉多少
DISCOVER_MAX_REPOS=1500
# 多维度发现：新秀(近N天创建已有star)
DISCOVER_RISING_MAX=500
DISCOVER_RISING_DAYS=365
# 多维度发现：活跃中小(star<=active_star_max 且近N天有push)
DISCOVER_ACTIVE_MAX=500
DISCOVER_ACTIVE_DAYS=30
DISCOVER_ACTIVE_STAR_MAX=15000

# 启动时开启每日自动流水线（本地调试 false，生产 true）
ENABLE_SCHEDULER=false

# JWT 认证（生产务必改成随机长字符串）
JWT_SECRET=change-me-in-production
JWT_EXPIRE_DAYS=30

# ---- Phase 4 预留，留空则相关功能自动跳过 ----
# AI 摘要（Anthropic）
ANTHROPIC_API_KEY=
# 邮件推送（如 Gmail 应用密码 / SendGrid）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
