# 生产部署密钥（复制为 .env.prod，勿提交到版本库）
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- Postgres ---
POSTGRES_USER=radar
POSTGRES_PASSWORD=请改成强密码
POSTGRES_DB=github_radar

# --- 站点 ---
SITE_URL=https://radar.mxzshs.com
# 前端暴露到宿主机的端口（宿主 nginx 反代到这里；避开 kids 的 80/443）
WEB_PORT=8090

# --- GitHub 采集 token（逗号分隔可多个轮换）---
GITHUB_TOKENS=ghp_xxx

# --- 安全（务必改）---
JWT_SECRET=用 openssl rand -hex 32 生成
ADMIN_TOKEN=用 openssl rand -hex 32 生成

# --- 可选 ---
SENTRY_DSN=
ANTHROPIC_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- 发现规模 ---
DISCOVER_MIN_STARS=500
DISCOVER_MAX_REPOS=1500
